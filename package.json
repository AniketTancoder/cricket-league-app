{
  "name": "cricket-league-app",
  "version": "1.0.0",
  "description": "Production-ready Cricket League Management Web App",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev:server",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:server": "nodemon src/index.js",
    "build": "cd frontend && npm run build",
    "start": "cd backend && node src/index.js",
    "db:generate": "cd backend && npx prisma generate",
    "db:push": "cd backend && npx prisma db push",
    "db:seed": "cd backend && node prisma/seed.js",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install"
  },
  "keywords": ["cricket", "league", "management"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
